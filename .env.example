
# Postgres superuser password (used only during DB init)
POSTGRES_SUPERUSER_PASSWORD=

# Per-service DB passwords
REG_DB_PASSWORD=
BALLOT_DB_PASSWORD=
TALLY_DB_PASSWORD=

# Shared HMAC secret for signing ballot tokens
# can generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
TOKEN_SECRET=

# Admin secret for the tally service setup and start endpoints.
# can generate with: python3 -c "import secrets; print(secrets.token_hex(24))"
ADMIN_SECRET=
